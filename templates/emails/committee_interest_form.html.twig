<!DOCTYPE html>
<html>
<body>
<p>Hey,</p>

<p>
    <a href="{{ url('profile.member', {member_id: member.id})}}">{{ member.full_name }}</a>
    indicated that they want more information about committees.
</p>

{% if hobbies != '' %}
<p>
    They have selected the following hobbies:
    {{ hobbies }}
