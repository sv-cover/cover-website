{% extends '@layout/layout.html.twig' %}

{% block title __('Committee interest') ~ ' – ' ~ parent() %}

{% block page %}
<section class="section">
    <div class="container photo-book">
        <header class="hero is-light">

            <div class="hero-body">
                <h1 class="title has-text-centered is-centered">Committee Interest Form</h1>
            </div>

            <div class="hero-foot">
                <nav class="tabs is-boxed is-fullwidth has-background-light">
                    <div class="container">
                        <ul>
                            <li class="{{ activeMode == 'join' ? 'has-background-primary' : ''}}">
                                <a  href="{{ path('committees.join', {mode: 'join'}) }}">I want to join a committee</a>
                            </li>
                            <li class="{{ activeMode == 'interest' ? 'has-background-primary' : ''}}">
                                <a href="{{ path('committees.join', {mode: 'interest'}) }}">I want more information about committees</a>
                            </li>
                        </ul>
                    </div>
                </nav>
            </div>
        </header>

        <section class="section">
            {% if activeMode == 'join' %}
                {{ form_start(form) }}

                {# Global errors #}
                {{ form_errors(form) }}

                {# Form fields #}

                {{ form_row(form.name )}}

                {{ form_row(form.committee) }}


                {{ form_row(form.submit) }}
                {{ form_end(form) }}
            {% elseif activeMode == 'interest' %}
                <h1>INTEREST</h1>
            {% endif %}
        </section>

    </div>
</section>

{% endblock %}