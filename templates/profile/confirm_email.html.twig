{% extends '@layout/layout.html.twig' %}

{% block title __('Confirm email') ~ ' – ' ~ parent() %}

{% block content %}
<h1 class="title">{{ __('Confirm email') }}</h1>
<article class="content">
    {% if success %}
        <p>{{ __('Finished! Your email has been confirmed and updated!') }}</p>
    {% else %}
        <p>{{ __('Oh dear, this link is no longer valid.') }}</p>
        <p>{{ __('It might be the case that you’ve already confirmed your email. Try to log in with your new email. It that doesn’t work, try to use your previous email once again. Did you forget your password? You might want to try both your previous and current email when asking for password recovery.') }}</p>
        {# TODO SFY #}
        {# <p>{{ __('Still having trouble? Send an email to %s and we’ll help you.')|e|format(html_email(global.config.email_support))|raw }}</p> #}
    {% endif %}
    <a href="{{ path('homepage') }}" class="button">{{ __('Back to the homepage') }}</a>
</article>
{% endblock %}
