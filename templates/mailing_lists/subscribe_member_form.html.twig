{% extends '@layout/layout.html.twig' %}

{% block title __('Subscribe a member') ~ ' – ' ~ parent() %}

{% block content %}
<div class="modal is-static">
    <div class="modal-card">
        <header class="modal-card-head">
            <p class="modal-card-title">{{ __('Add member') }}</p>
        </header>
        <section class="modal-card-body">
            {{ form_start(form, {'id': 'subscribe-member-form', 'action': path('mailing_lists.subscribe_member', {id: list.id})}) }}
                {# Global errors #}
                {{ form_errors(form) }}
                {# Fields #}
                {{ form_row(form.member_id) }}
                {% set submit_button = form_widget(form.submit, {'label': __('Subscribe'), 'attr': {'form': 'subscribe-member-form'}})%}
            {{ form_end(form) }}
        </section>
        <footer class="modal-card-foot">
            <a href="{{ path('mailing_lists.single', {id: list.id}) }}" class="button" data-dismiss="modal">{{ __('Cancel') }}</a>
            {{ submit_button|raw }}
        </footer>
    </div>
</div>
{% endblock %}
