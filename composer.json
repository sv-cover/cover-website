{
    "require": {
        "maennchen/zipstream-php": "^3.1",
        "jeroendesloovere/vcard": "^1.7",
        "twig/twig": "^3.8",
        "giggsey/libphonenumber-for-php": "^8.13",
        "symfony/routing": "v7.1.0",
        "symfony/config": "v7.1.0",
        "symfony/expression-language": "v7.1.0",
        "symfony/yaml": "v7.1.0",
        "symfony/apache-pack": "^1.0",
        "symfony/form": "v7.1.0",
        "symfony/validator": "v7.1.0",
        "symfony/twig-bridge": "v7.1.0",
        "symfony/http-foundation": "v7.1.0",
        "symfony/security-csrf": "v7.1.0",
        "symfony/intl": "v7.1.0",
        "symfony/mime": "v7.1.0",
        "odolbeau/phone-number-bundle": "v4.0.0",
        "sentry/sdk": "^4.0",
        "twig/intl-extra": "^3.8",
        "symfony/uid": "^7.1"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0"
    },
    "scripts": {
        "test": "phpunit tests"
    },
    "autoload": {
        "psr-4": {
            "App\\Controller\\": "src/controllers/",
            "App\\Form\\": "src/Form/",
            "App\\Validator\\": "src/Validator/",
            "fields\\": "src/fields/"
        }
    },
    "config": {
        "allow-plugins": {
            "php-http/discovery": true
        }
    }
}
