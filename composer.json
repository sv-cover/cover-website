{
    "require": {
        "maennchen/zipstream-php": "^2.2",
        "jeroendesloovere/vcard": "^1.7",
        "twig/twig": "^3.8",
        "giggsey/libphonenumber-for-php": "^8.13",
        "symfony/routing": "^6.4",
        "symfony/config": "^6.4",
        "symfony/expression-language": "^6.4",
        "symfony/yaml": "^6.4",
        "symfony/apache-pack": "^1.0",
        "symfony/form": "^6.4",
        "symfony/validator": "^6.4",
        "symfony/twig-bridge": "^6.4",
        "symfony/http-foundation": "^6.4",
        "symfony/security-csrf": "^6.4",
        "symfony/intl": "^6.4",
        "symfony/mime": "^6.4",
        "odolbeau/phone-number-bundle": "^3.9",
        "sentry/sdk": "^4.0",
        "twig/intl-extra": "^3.8"
    },
    "require-dev": {
        "phpunit/phpunit": "^9.5"
    },
    "scripts": {
        "test": "phpunit tests"
    },
    "autoload": {
        "psr-4": {
            "App\\Controller\\": "src/controllers/",
            "App\\Form\\": "src/Form/",
            "App\\Validator\\": "src/Validator/",
            "fields\\": "src/fields/"
        }
    },
    "config": {
        "allow-plugins": {
            "php-http/discovery": true
        }
    }
}
